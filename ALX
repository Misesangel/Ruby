# A module to provide search functionality across different classes
module Searchable
  def find_by_title(collection, title)
    collection.select { |item| item.title.downcase.include?(title.downcase) }
  end
end

# Base class for all library items
class LibraryItem
  attr_accessor :title, :author, :id
  
  def initialize(title, author, id)
    @title = title
    @author = author
    @id = id
    @available = true
  end

  def available?
    @available
  end

  def checkout
    raise "Item already checked out!" unless @available
    @available = false
  end

  def return_item
    @available = true
  end
end

# Specific class for Books, inheriting from LibraryItem
class Book < LibraryItem
  attr_reader :pages
  
  def initialize(title, author, id, pages)
    super(title, author, id)
    @pages = pages
  end

  def to_s
    "[Book] '#{@title}' by #{@author} (#{@pages} pages) - Status: #{@available ? 'Available' : 'On Loan'}"
  end
end

# Class to manage the Library collection
class Library
  include Searchable
  
  def initialize(name)
    @name = name
    @books = []
  end

  def add_book(book)
    @books << book
    puts "Added: #{book.title}"
  end

  def list_books
    puts "\n--- #{@name} Collection ---"
    @books.each { |book| puts book }
  end

  def find_books(title)
    results = find_by_title(@books, title)
    puts "\nSearch Results for '#{title}':"
    results.any? ? results.each { |b| puts b } : puts("No books found.")
  end
end

